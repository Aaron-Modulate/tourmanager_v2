{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Bricolage Grotesque|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Bricolage Grotesque, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|mono|block|iconLeft|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, mono, block, iconLeft, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|stage|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'stage' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|type|mono|hint|prefix|suffix|disabled|invalid|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, value, onChange, placeholder, type, mono, hint, prefix, suffix, disabled, invalid, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|dot|hard|style|key|ref|className|style|children)$/]",
        "message": "<SignalChip> doesn't accept that prop. Declared props: children, tone, variant, size, dot, hard, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:load|sound|doors|live|stop|brand|ink)$/]",
        "message": "<SignalChip> tone must be one of 'load' | 'sound' | 'doors' | 'live' | 'stop' | 'brand' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalChip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|tint|outline)$/]",
        "message": "<SignalChip> variant must be one of 'solid' | 'tint' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignalChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SignalChip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StampCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|overline|tone|hard|halftone|padding|style|key|ref|className|style|children)$/]",
        "message": "<StampCard> doesn't accept that prop. Declared props: children, overline, tone, hard, halftone, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StampCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|raised|stage)$/]",
        "message": "<StampCard> tone must be one of 'paper' | 'raised' | 'stage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|value|onChange|tone|style|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, value, onChange, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|stage)$/]",
        "message": "<Tabs> tone must be one of 'paper' | 'stage'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
